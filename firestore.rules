rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if the current user is an admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── ADMIN BYPASS ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // ── PGs (Properties) ───────────────────────────────────────────────────
    match /pgs/{pgId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.caretakerId == request.auth.uid
      );
    }

    // ── Bookings ───────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // ── Payment Sessions ──────────────────────────────────────────────────
    match /paymentSessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    // ── Payments (Receipts) — no delete, permanent records ────────────────
    match /payments/{paymentId} {
      allow read, create, update: if request.auth != null;
    }

    // ── Complaints ─────────────────────────────────────────────────────────
    match /complaints/{complaintId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // ── Notifications ──────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // ── Contracts ──────────────────────────────────────────────────────────
    match /contracts/{contractId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // ── Caretakers ─────────────────────────────────────────────────────────
    match /caretakers/{caretakerId} {
      allow read, create, update: if request.auth != null;
    }

    // ── Verifications (KYC) ────────────────────────────────────────────────
    match /verifications/{userId} {
      allow read, write: if request.auth != null;
    }

    // ── Reviews — public read, auth create ─────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    // ── Community Messages ─────────────────────────────────────────────────
    match /communityMessages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── Community Presence ─────────────────────────────────────────────────
    match /communityPresence/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
